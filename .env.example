# =============================================================================
# One API Environment Configuration
# Copy this file to .env and modify the values as needed.
# =============================================================================

# --- Server ---
PORT=3000
# GIN_MODE=release  # Set to "release" for production

# --- Database ---
# MySQL (recommended for production)
SQL_DSN=oneapi:123456@tcp(db:3306)/one-api
# PostgreSQL alternative:
# SQL_DSN=postgres://oneapi:123456@db:5432/one-api?sslmode=disable
# Leave SQL_DSN empty to use SQLite (default, stored in /data)
# SQLITE_PATH=/data/one-api.db

# Optional: separate database for logs
# LOG_SQL_DSN=oneapi:123456@tcp(db:3306)/one-api-logs

# Database connection pool
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60

# --- Redis (required for subscription window counting) ---
REDIS_CONN_STRING=redis://redis
# For Redis Sentinel:
# REDIS_CONN_STRING=redis1:6379,redis2:6379,redis3:6379
# REDIS_MASTER_NAME=mymaster
# REDIS_PASSWORD=your_redis_password

# SYNC_FREQUENCY must be set for Redis to be enabled.
# Unit: seconds. Controls cache sync interval for tokens, user groups, quotas.
SYNC_FREQUENCY=60

# --- Session ---
# IMPORTANT: Change this to a random string in production!
SESSION_SECRET=change-me-to-a-random-string

# --- Performance ---
MEMORY_CACHE_ENABLED=true
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5

# --- Debug ---
DEBUG=false
# DEBUG_SQL=false

# --- Rate Limiting ---
# GLOBAL_API_RATE_LIMIT=480
# GLOBAL_WEB_RATE_LIMIT=240

# --- Relay ---
# RELAY_TIMEOUT=0          # Request timeout in seconds (0 = no timeout)
# RELAY_PROXY=              # HTTP proxy for relay requests
# ENFORCE_INCLUDE_USAGE=false

# --- Multi-node Deployment ---
# NODE_TYPE=slave           # Set to "slave" for worker nodes
# FRONTEND_BASE_URL=https://your-domain.com

# --- Initial Setup (first launch only) ---
# INITIAL_ROOT_TOKEN=sk-xxx          # Pre-set root API token
# INITIAL_ROOT_ACCESS_TOKEN=xxx      # Pre-set root access token

# --- Docker Compose Database Credentials ---
MYSQL_ROOT_PASSWORD=OneAPI@justsong
MYSQL_USER=oneapi
MYSQL_PASSWORD=123456
MYSQL_DATABASE=one-api

# --- Timezone ---
TZ=Asia/Shanghai

# --- Channel Testing ---
# CHANNEL_TEST_FREQUENCY=0  # Auto-test channels interval in minutes (0 = disabled)
# TEST_PROMPT=Output only your specific model name with no additional text.

# --- Gemini ---
# GEMINI_SAFETY_SETTING=BLOCK_NONE
# GEMINI_VERSION=v1

# --- Metrics ---
# ENABLE_METRIC=false
# METRIC_QUEUE_SIZE=10
# METRIC_SUCCESS_RATE_THRESHOLD=0.8

# --- Theme ---
# THEME=default  # Options: default, berry, air
